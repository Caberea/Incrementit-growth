// Script assets have changed for v2.3.0 see
// https://help.yoyogames.com/hc/en-us/articles/360005277377 for more information
function scr_init_sprite_array(){
var i = 0;

sprite_array[i++] = spr_up;
sprite_array[i++] = spr_down;
sprite_array[i++] = spr_left;
sprite_array[i++] = spr_right;
sprite_array[i++] = spr_up2;
sprite_array[i++] = spr_down2;
sprite_array[i++] = spr_left2;
sprite_array[i++] = spr_right2;
sprite_array[i++] = spr_wrong;

return;
}