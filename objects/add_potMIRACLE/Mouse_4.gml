if (action1.scene = 12 && (counter_potMIRACLE.cost < (maintext.gold+1))){
maintext.gold = maintext.gold - counter_potMIRACLE.cost;
counter_potMIRACLE.buffvalue = counter_potMIRACLE.buffvalue + (1+(1*counter_potMIRACLE.amount));
counter_potMIRACLE.amount++;
}