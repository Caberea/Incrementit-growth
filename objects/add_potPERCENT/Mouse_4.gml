if (action1.scene = 12 && (counter_potPERCENT.cost < (maintext.gold+1))){
	if (counter_potPERCENT.buffvalue <100){
maintext.gold = maintext.gold - counter_potPERCENT.cost;
counter_potPERCENT.amount++;
counter_potPERCENT.buffvalue = counter_potPERCENT.buffvalue + 10;
	}
}